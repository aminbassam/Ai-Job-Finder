# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jobflow:jobflow_dev@localhost:5432/jobflow

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Session TTL in seconds (7 days)
SESSION_TTL_SECONDS=604800

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5678

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Max requests per 15-minute window on auth routes
AUTH_RATE_LIMIT=20

# ── Email (optional — forgot-password emails) ─────────────────────────────────
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@jobflow.ai
# APP_URL=http://localhost:5678
