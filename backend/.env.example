# Core server
DATABASE_URL=postgresql://jobflow:jobflow_dev@localhost:5432/jobflow
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5678

# Auth
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d
SESSION_TTL_SECONDS=604800
AUTH_RATE_LIMIT=20

# App URLs
APP_URL=http://localhost:5678

# Optional seed credentials
# If omitted, the seed script generates a local-only admin password and prints it once.
SEED_ADMIN_EMAIL=admin@local.jobflow.test
SEED_ADMIN_PASSWORD=

# Google Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# Encryption
# Must be exactly 64 hex characters (32 bytes).
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-this-with-64-hex-characters

# Email
# Leave SMTP_HOST blank in local development to print emails to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=JobFlow AI <noreply@jobflow.ai>
